# 本文件只放「容器启动就需要」的基础设施密钥(compose 插值用)。
# 应用密钥(GATEWAY_JWT_SECRET / ADMIN_* / 供应商 Key)不在这里:
# 首次启动后在 Nacos 控制台(http://localhost:8850)的 llm-gateway.yaml 里填写,
# 然后 docker compose restart gateway。模板见 deploy/nacos-init/init.sh。

# ===== 必填 =====
# MySQL root 密码(容器内数据库;网关用它连库)
MYSQL_ROOT_PASSWORD=change-me
# Redis 密码(容器网络内也设密码作纵深防御)
REDIS_PASSWORD=change-me

# ===== 可选 =====
# 管理台对外端口
UI_PORT=8081
# 云上部署由 CI 注入指向 Registry 的镜像;本地开发留空走本地 build
# GATEWAY_IMAGE=
# UI_IMAGE=

# ===== Nacos / Sentinel(compose 内网自动接线,以下仅本机裸跑网关时用)=====
# NACOS_SERVER_ADDR=localhost:8848
# SENTINEL_DASHBOARD=localhost:8858
# GATEWAY_RATE_LIMIT_STORE=sentinel
